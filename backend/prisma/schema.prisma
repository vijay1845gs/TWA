// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum BillStatus {
  DRAFT
  FINALIZED
  CANCELLED
  RETURNED
}

enum BillType {
  LABOUR
  PARTS
  MIXED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  CREDIT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum AuditAction {
  LOGIN
  LOGOUT
  CREATE
  UPDATE
  DELETE
  GENERATE_PDF
  UPLOAD_IMAGE
  RESET_SYSTEM
  OTP_SENT
  OTP_VERIFIED
  EXPORT
}

// ─────────────────────────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────────────────────────

model User {
  id            String         @id @default(uuid())
  mobile        String         @unique @db.VarChar(15)
  name          String         @db.VarChar(100)
  role          Role           @default(STAFF)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  pin           UserPin?
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  galleryImages GalleryImage[]
  bills         Bill[]         @relation("CreatedBy")

  @@map("users")
}

model UserPin {
  id        String   @id @default(uuid())
  userId    String   @unique
  pinHash   String   @db.Text
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_pins")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @db.Text
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model OtpRecord {
  id        String   @id @default(uuid())
  mobile    String   @db.VarChar(15)
  otpHash   String   @db.Text
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([mobile])
  @@map("otp_records")
}

// ─────────────────────────────────────────────────────────────────
// CUSTOMERS (TRANSPORT COMPANIES)
// ─────────────────────────────────────────────────────────────────

model Customer {
  id        String    @id @default(uuid())
  name      String    @db.VarChar(150)
  nameTA    String?   @db.VarChar(200)
  mobile    String?   @db.VarChar(15)
  email     String?   @db.VarChar(150)
  address   String?   @db.Text
  gstin     String?   @db.VarChar(15)
  isPreset  Boolean   @default(false)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  vehicles Vehicle[]
  bills    Bill[]

  @@index([name])
  @@map("customers")
}

model Vehicle {
  id          String   @id @default(uuid())
  plateNumber String   @unique @db.VarChar(20)
  model       String?  @db.VarChar(100)
  type        String?  @db.VarChar(50)
  customerId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id])
  bills    Bill[]

  @@index([plateNumber])
  @@map("vehicles")
}

// ─────────────────────────────────────────────────────────────────
// WELDING SERVICES MASTER
// ─────────────────────────────────────────────────────────────────

model Service {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(200)
  nameTA      String?  @db.VarChar(300)
  defaultRate Decimal? @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@map("services")
}

// ─────────────────────────────────────────────────────────────────
// PRODUCTS & INVENTORY (V2 — tables exist, APIs are stubs in V1)
// ─────────────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(uuid())
  name        String    @unique @db.VarChar(100)
  description String?   @db.Text
  createdAt   DateTime  @default(now())

  products Product[]

  @@map("categories")
}

model Product {
  id         String    @id @default(uuid())
  name       String    @db.VarChar(150)
  nameTA     String?   @db.VarChar(200)
  sku        String    @unique @db.VarChar(50)
  barcode    String?   @db.VarChar(100)
  categoryId String?
  unitPrice  Decimal   @db.Decimal(10, 2)
  taxPercent Decimal   @default(18.00) @db.Decimal(5, 2)
  isService  Boolean   @default(false)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  category  Category?  @relation(fields: [categoryId], references: [id])
  inventory Inventory?
  billItems BillItem[]

  @@index([name])
  @@index([sku])
  @@map("products")
}

model Inventory {
  id                String   @id @default(uuid())
  productId         String   @unique
  stockQty          Decimal  @default(0) @db.Decimal(10, 2)
  lowStockThreshold Decimal  @default(5) @db.Decimal(10, 2)
  unit              String   @default("pcs") @db.VarChar(20)
  updatedAt         DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("inventory")
}

// ─────────────────────────────────────────────────────────────────
// BILLING
// ─────────────────────────────────────────────────────────────────

model Bill {
  id            String     @id
  type          BillType   @default(LABOUR)
  status        BillStatus @default(DRAFT)
  customerId    String?
  vehicleId     String?
  clientName    String     @db.VarChar(150)
  vehicleNumber String?    @db.VarChar(20)

  // Financial totals (computed and stored for fast reads)
  subtotal   Decimal @default(0) @db.Decimal(12, 2)
  discountAmt Decimal @default(0) @db.Decimal(12, 2)
  taxableAmt  Decimal @default(0) @db.Decimal(12, 2)
  cgstAmt    Decimal @default(0) @db.Decimal(12, 2)
  sgstAmt    Decimal @default(0) @db.Decimal(12, 2)
  igstAmt    Decimal @default(0) @db.Decimal(12, 2)
  grandTotal  Decimal @default(0) @db.Decimal(12, 2)

  notes       String?  @db.Text
  createdById String?
  billedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer  Customer?  @relation(fields: [customerId], references: [id])
  vehicle   Vehicle?   @relation(fields: [vehicleId], references: [id])
  createdBy User?      @relation("CreatedBy", fields: [createdById], references: [id])
  items     BillItem[]
  payments  Payment[]
  receipt   Receipt?

  language  String     @default("EN") @db.VarChar(5)

  @@index([status])
  @@index([customerId])
  @@index([billedAt])
  @@index([vehicleNumber])
  @@map("bills")
}

model BillItem {
  id          String  @id @default(uuid())
  billId      String
  productId   String?
  description String  @db.VarChar(300)
  quantity    Decimal @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(10, 2)
  discountAmt Decimal @default(0) @db.Decimal(10, 2)
  taxPercent  Decimal @default(0) @db.Decimal(5, 2)
  taxAmt      Decimal @default(0) @db.Decimal(10, 2)
  subtotal    Decimal @db.Decimal(12, 2)
  sortOrder   Int     @default(0)

  bill    Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([billId])
  @@map("bill_items")
}

// ─────────────────────────────────────────────────────────────────
// PAYMENTS (V1 simplified — one payment per finalized bill)
// ─────────────────────────────────────────────────────────────────

model Payment {
  id        String        @id @default(uuid())
  billId    String
  method    PaymentMethod @default(CASH)
  status    PaymentStatus @default(COMPLETED)
  amount    Decimal       @db.Decimal(12, 2)
  reference String?       @db.VarChar(100)
  paidAt    DateTime      @default(now())
  notes     String?       @db.Text
  createdAt DateTime      @default(now())

  bill Bill @relation(fields: [billId], references: [id])

  @@index([billId])
  @@index([paidAt])
  @@map("payments")
}

// ─────────────────────────────────────────────────────────────────
// RECEIPTS
// ─────────────────────────────────────────────────────────────────

model Receipt {
  id            String   @id @default(uuid())
  billId        String   @unique
  pdfUrl        String   @db.Text
  storageKey    String   @db.Text
  generatedAt   DateTime @default(now())
  downloadCount Int      @default(0)

  bill Bill @relation(fields: [billId], references: [id])

  @@map("receipts")
}

// ─────────────────────────────────────────────────────────────────
// GALLERY
// ─────────────────────────────────────────────────────────────────

model GalleryImage {
  id           String   @id @default(uuid())
  title        String   @db.VarChar(200)
  imageUrl     String   @db.Text
  storageKey   String   @db.Text
  uploadedById String?
  createdAt    DateTime @default(now())

  uploadedBy User? @relation(fields: [uploadedById], references: [id])

  @@map("gallery_images")
}

// ─────────────────────────────────────────────────────────────────
// ENQUIRIES (Book a Call from landing page)
// ─────────────────────────────────────────────────────────────────

model Enquiry {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(100)
  mobile      String   @db.VarChar(15)
  description String   @db.Text
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@map("enquiries")
}

// ─────────────────────────────────────────────────────────────────
// BILL NUMBER SEQUENCES (atomic, per year per type)
// ─────────────────────────────────────────────────────────────────

model BillSequence {
  id      String @id @default(uuid())
  prefix  String @db.VarChar(10)
  year    Int
  lastSeq Int    @default(0)

  @@unique([prefix, year])
  @@map("bill_sequences")
}

// ─────────────────────────────────────────────────────────────────
// SETTINGS (KV store)
// ─────────────────────────────────────────────────────────────────

model Setting {
  key       String   @id @db.VarChar(100)
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ─────────────────────────────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────────────────────────────

model AuditLog {
  id        String      @id @default(uuid())
  userId    String?
  action    AuditAction
  entity    String      @db.VarChar(50)
  entityId  String?     @db.VarChar(100)
  oldValues Json?
  newValues Json?
  ipAddress String?     @db.VarChar(45)
  userAgent String?     @db.Text
  createdAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
